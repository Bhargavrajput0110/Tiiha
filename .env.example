# Shiprocket API Credentials (get from Shiprocket dashboard → Settings → API)
SHIPROCKET_EMAIL=your-shiprocket@email.com
SHIPROCKET_PASSWORD=your-shiprocket-password

# Razorpay API Credentials (get from Razorpay dashboard → Settings → API Keys)
# Key ID starts with rzp_live_ (live) or rzp_test_ (test mode)
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_SECRET_KEY_HERE

# Frontend URL for CORS (your deployed domain)
FRONTEND_URL=https://tiiha.in

# Port for the backend server
PORT=3000

# SMTP Email Configuration (for order confirmation emails)
# Example: Gmail, SendGrid, Brevo, AWS SES
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password